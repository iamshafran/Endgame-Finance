<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Local bill notifications (Milestone 3). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- INTERNET added in Milestone 7 (owner-approved, 2026-07-14) for the SINGLE
         purpose of an in-app, user-initiated download of the on-device AI model.
         This is the app's only network use: no analytics, no telemetry, no data
         ever leaves the device, and AI inference runs fully offline. The
         onboarding and Settings > About copy are updated to state this honestly.
         ACCESS_NETWORK_STATE (WorkManager + our connectivity check) is now kept. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Package visibility (Android 11+): the notification-capture picker
         (Milestone 8.1) lists the user's launchable apps so they can whitelist
         their bank/card apps. We deliberately query only LAUNCHER apps rather
         than requesting the Play-restricted QUERY_ALL_PACKAGES — no package
         data leaves the device. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".EndgameApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EndgameFinance">

        <!-- Allow loading the device's OpenCL driver so LiteRT-LM's GPU backend
             works (Android 12+ blocks dlopen of vendor native libs unless
             declared). All optional — CPU fallback covers devices without them. -->
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-car.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-pixel.so" android:required="false" />
        <uses-native-library android:name="libGLES_mali.so" android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Milestone 8.1: reads notifications from user-whitelisted banking apps
             to propose transactions. Enabled only when the user grants notification
             access AND opts a source in; parsing is fully on-device. The OS requires
             this service be exported and bound with BIND_NOTIFICATION_LISTENER_SERVICE. -->
        <service
            android:name=".notifications.TransactionCaptureListenerService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Handles Confirm/Dismiss on a captured-transaction notification.
             Not exported: only our own PendingIntents trigger it. -->
        <receiver
            android:name=".notifications.NotificationConfirmReceiver"
            android:exported="false" />

        <!-- Lets the system camera write a captured receipt photo into our cache
             (Milestone 8.2). No CAMERA permission needed — capture is delegated
             to the camera app. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
